---
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import CTASection from "@components/CTASection.astro";
import WhatsAppLink from "@components/WhatsAppLink.astro";
import { images } from "@data/images";
---

<BaseLayout title="West Africa Custom Trips | Your Mali Guides" description="Plan selected West Africa routes with Djibril Kassogue and his local network, depending on borders, visas, transport, and security conditions.">
  <section class="section-pad bg-cream">
    <div class="container-site grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <SectionHeading eyebrow="West Africa" title="Custom cross-border routes, planned carefully." text="Djibril and his network can help with selected West Africa routes depending on current border, visa, transport, and security conditions." />
      <img src={images.westAfrica} alt="Travellers planning a West Africa route" class="h-96 w-full rounded-lg object-cover shadow-xl" />
    </div>
  </section>
  <section class="section-pad bg-white">
    <div class="container-site grid gap-6 md:grid-cols-2">
      {["Burkina Faso", "Ivory Coast", "Guinea", "Guinea-Bissau", "Broader West Africa custom routes", "Mali plus neighbouring countries"].map((place) => (
        <article class="rounded-lg border border-slate-900/10 p-6 shadow-sm">
          <h2 class="font-serif text-3xl font-extrabold text-indigo-deep">{place}</h2>
          <p class="mt-3 leading-7 text-slate-700">Planning can include route design, local contacts, transport, timing, visas, border practicalities, and safety-first decisions.</p>
        </article>
      ))}
    </div>
    <div class="container-site mt-10 rounded-lg bg-indigo-deep p-8 text-white">
      <h2 class="font-serif text-4xl font-extrabold">Safety-first route design</h2>
      <p class="mt-4 max-w-3xl leading-8 text-white/78">West Africa routes require current information. Always check current travel advisories and entry requirements before booking international travel.</p>
      <div class="mt-6"><WhatsAppLink label="Ask about West Africa" /></div>
    </div>
  </section>
  <CTASection title="Planning a West Africa route?" text="Message Djibril with your countries, dates, passport nationality, and travel style." />
</BaseLayout>
