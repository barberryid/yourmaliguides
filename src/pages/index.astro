<style>
  /* Niger River photo strip */
  .river-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    background: var(--ink);
  }
  .river-strip picture,
  .river-strip img {
    display: block;
    width: 100%;
    height: clamp(260px, 38vw, 520px);
    object-fit: cover;
  }
  @media (max-width: 680px) {
    .river-strip {
      grid-template-columns: 1fr;
    }
    .river-strip picture,
    .river-strip img {
      height: 70vw;
    }
  }

  /* Hero glassmorphism card */
  .hero-glass-card {
    border-radius: 2rem;
    padding: clamp(1.4rem, 3.5vw, 2.6rem);
    background: linear-gradient(135deg, rgba(253, 250, 243, 0.72), rgba(253, 250, 243, 0.48));
    border: 1px solid rgba(255, 255, 255, 0.62);
    box-shadow:
      0 24px 70px rgba(12, 50, 45, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.80);
    backdrop-filter: blur(22px) saturate(140%);
    -webkit-backdrop-filter: blur(22px) saturate(140%);
  }

  @media (max-width: 720px) {
    .hero-glass-card {
      border-radius: 1.5rem;
      background: linear-gradient(135deg, rgba(253, 250, 243, 0.84), rgba(253, 250, 243, 0.62));
    }
  }

  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .hero-glass-card {
      background: rgba(253, 250, 243, 0.92);
    }
  }

  /* First message card */
  .first-msg-card {
    background: white;
    border: 1px solid var(--sand);
    border-radius: 18px;
    box-shadow: var(--shadow-hero-card);
    margin-top: -72px;
    position: relative;
    z-index: 10;
    padding: clamp(28px, 4vw, 44px);
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }

  /* Routes grid */
  .routes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* About grid */
  .about-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(36px, 5vw, 72px);
    align-items: center;
  }

  /* Steps grid */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(28px, 4vw, 48px);
  }

  /* Photo mosaic */
  .photo-mosaic {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 200px;
    gap: 14px;
  }

  /* Safety grid */
  .safety-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(36px, 5vw, 72px);
    align-items: start;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .routes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .steps-grid {
      grid-template-columns: 1fr;
    }
    .photo-mosaic {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 680px) {
    .first-msg-card {
      grid-template-columns: 1fr;
      margin-top: -40px;
    }
    .routes-grid {
      grid-template-columns: 1fr;
    }
    .about-grid {
      grid-template-columns: 1fr;
    }
    .safety-grid {
      grid-template-columns: 1fr;
    }
    .photo-mosaic {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 140px;
    }
  }
</style>

<script>
  // FAQ accordion
  const faqItems = document.querySelectorAll(".faq-item");
  faqItems.forEach((item) => {
    const btn = item.querySelector(".faq-btn");
    btn?.addEventListener("click", () => {
      const isOpen = item.classList.contains("open");
      faqItems.forEach((el) => {
        el.classList.remove("open");
        el.querySelector(".faq-btn")?.setAttribute("aria-expanded", "false");
      });
      if (!isOpen) {
        item.classList.add("open");
        btn.setAttribute("aria-expanded", "true");
      }
    });
  });
</script>
