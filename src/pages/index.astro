---
import BaseLayout from "@layouts/BaseLayout.astro";
import RouteCard from "@components/RouteCard.astro";
import FinalCTA from "@components/FinalCTA.astro";
import { site } from "@config/site";

const waMain = `${site.whatsappUrl}?text=${encodeURIComponent(site.whatsappMessage)}`;
const waRoute = (topic: string) =>
  `${site.whatsappUrl}?text=${encodeURIComponent(`Hello Djibril, I am interested in ${topic}. My dates are: ___. Number of travellers: ___. Could you advise what is realistic?`)}`;
const waSafety = `${site.whatsappUrl}?text=${encodeURIComponent("Hello Djibril, I would like to ask about the safety and feasibility of a Mali trip for my dates: ___.")}`;

const trustChips = [
  "Official registered guide",
  "Real local knowledge",
  "Custom private trips",
  "References available",
  "Safety-aware planning",
];

const routes = [
  {
    title: "Bamako City and Culture",
    image: "/images/bamako-city-culture.webp",
    alt: "Bamako city life, markets, and culture",
    bestFor: "Arrival days, short stays, and first-time visitors.",
    note: "A good standalone option or first step before travelling further.",
    feasibility: "Open to visitors",
    feasColor: "rgba(31,76,59,0.85)",
    topic: "Bamako City and Culture",
    ideaUrl: "/tours/#bamako",
  },
  {
    title: "Djenné and Mopti",
    image: "/images/djenne-mud-mosque.webp",
    alt: "Djenné mud mosque and Mopti river town",
    bestFor: "Travellers interested in heritage towns and river culture.",
    note: "Only advised when current local conditions make the route realistic.",
    feasibility: "Conditions permitting",
    feasColor: "rgba(196,154,58,0.90)",
    topic: "Djenné and Mopti",
    ideaUrl: "/tours/#djenne-mopti",
  },
  {
    title: "Dogon Country",
    image: "/images/dogon-country-landscape.webp",
    alt: "Dogon Country cliffs and traditional villages",
    bestFor: "Cultural heritage travellers with flexible plans.",
    note: "Dogon routes are assessed case by case with current local advice.",
    feasibility: "Feasibility checked first",
    feasColor: "rgba(184,88,50,0.90)",
    topic: "Dogon Country",
    ideaUrl: "/tours/#dogon",
  },
  {
    title: "Timbuktu and Desert Routes",
    image: "/images/desert-route.webp",
    alt: "Timbuktu and northern Mali desert landscape",
    bestFor: "Experienced travellers who understand plans may need adjustment.",
    note: "Never promised blindly — feasibility is checked before plans are confirmed.",
    feasibility: "Feasibility checked first",
    feasColor: "rgba(184,88,50,0.90)",
    topic: "Timbuktu and Desert Routes",
    ideaUrl: "/tours/#timbuktu",
  },
  {
    title: "Mali and Burkina Faso",
    image: "/images/west-africa-route.webp",
    alt: "West Africa cross-border route planning",
    bestFor: "Flexible travellers planning selected West Africa routes.",
    note: "Designed around current border, transport, and security conditions.",
    feasibility: "Conditions permitting",
    feasColor: "rgba(196,154,58,0.90)",
    topic: "a Mali and Burkina Faso route",
    ideaUrl: "/west-africa/",
  },
  {
    title: "West Africa Custom Route",
    image: "/images/djibril-kassogue-portrait.webp",
    alt: "Custom West Africa private guiding route",
    bestFor: "Travellers with specific dates, interests, or countries in mind.",
    note: "Send dates, group size, interests, and the countries you hope to include.",
    feasibility: "Open to visitors",
    feasColor: "rgba(31,76,59,0.85)",
    topic: "a custom West Africa route",
    ideaUrl: "/custom-trip/",
  },
];

const reasons = [
  {
    title: "Official Local Guide",
    body: "Djibril is an official and registered guide in Mali, with experience helping travellers understand the country beyond surface-level tourism.",
  },
  {
    title: "Real Local Knowledge",
    body: "Local language, cultural context, trusted contacts, and day-to-day problem solving make a meaningful difference on the road.",
  },
  {
    title: "Safer Logistics",
    body: "Routes are planned with current local conditions, practical timing, transport realities, and safety considerations in mind.",
  },
  {
    title: "Fairer Prices",
    body: "A local guide helps reduce the stress of negotiating transport, services, and visits alone.",
  },
  {
    title: "Custom Itineraries",
    body: "Plans are built around your dates, interests, budget level, preferred language, and places you want to visit.",
  },
  {
    title: "West Africa Experience",
    body: "Djibril and his network can support selected routes across Mali, Burkina Faso, Ivory Coast, Guinea, and nearby countries.",
  },
];

const steps = [
  {
    n: "1",
    text: "Send your dates, group size, language preference, and places of interest on WhatsApp.",
  },
  {
    n: "2",
    text: "Djibril checks timing, transport, current feasibility, and route options.",
  },
  {
    n: "3",
    text: "You agree a private plan that fits your pace and practical conditions on the ground.",
  },
];

const gallery = [
  { src: "/images/girls-calabash.jpg", alt: "Girls with calabash bowls at a community gathering", col: "span 2", row: "span 2" },
  { src: "/images/feather-dancer.jpg", alt: "Ceremonial dancer in feathered costume", col: "span 1", row: "span 2" },
  { src: "/images/fishermen-nets.jpg", alt: "Fishermen casting nets on the river", col: "span 1", row: "span 1" },
  { src: "/images/fishing-village.jpg", alt: "Riverside fishing village in West Africa", col: "span 1", row: "span 1" },
  { src: "/images/women-indigo.jpg", alt: "Women in indigo-dyed traditional cloth", col: "span 1", row: "span 1" },
  { src: "/images/initiates-dance.jpg", alt: "Initiates performing a traditional dance ceremony", col: "span 1", row: "span 1" },
];

const safetyPoints = [
  { title: "Current local advice", body: "Routes are assessed against the latest ground-level information, not outdated guides." },
  { title: "Routes assessed case by case", body: "Each request is judged individually — no blanket promises about what is or isn't accessible." },
  { title: "Transport and timing checked", body: "Practical factors like road conditions, transport links, and seasonal timing all affect the plan." },
  { title: "Alternative plans when needed", body: "If a route is not realistic, Djibril will suggest what is — not just say no." },
];

const checklist = [
  "Your travel dates",
  "Number of travellers",
  "Arrival city",
  "Places you hope to visit",
  "Preferred language",
  "Budget level",
  "Travel pace",
  "Any safety concerns",
];

const aboutTags = [
  "Speaks local languages",
  "Trusted local contacts",
  "Years of guiding",
  "West Africa network",
];

const faqs = [
  {
    q: "Can I contact Djibril directly on WhatsApp?",
    a: "Yes. WhatsApp is the fastest way to reach Djibril. Send your dates, group size, preferred language, and the places you hope to visit.",
  },
  {
    q: "Can Djibril help plan a custom Mali itinerary?",
    a: "Yes. Djibril can advise what is practical under current conditions and help shape a realistic private itinerary around your interests.",
  },
  {
    q: "Which places in Mali can I visit with a local guide?",
    a: "Djibril can help plan Bamako visits, cultural routes, heritage towns, and selected longer routes when current local conditions make them realistic.",
  },
  {
    q: "Can I arrange a Bamako city tour?",
    a: "Yes. Bamako can work well as a first step or standalone visit, with markets, music, food, museums, neighbourhood life, and practical orientation.",
  },
  {
    q: "Can Djibril help with transport and local logistics?",
    a: "Yes. His support can include route planning, transport coordination, local contacts, cultural interpretation, and safety-aware logistics.",
  },
  {
    q: "What information should I send before booking?",
    a: "Send your travel dates, number of travellers, arrival city, places you want to visit, preferred language, budget level, travel pace, and any safety or timing concerns.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: { "@type": "Answer", text: faq.a },
  })),
};
---

<BaseLayout
  title="Private Mali Guide & Cultural Tours | Your Mali Guides"
  description="Plan a private Mali trip with Djibril Kassogue, an official local guide for Bamako visits, cultural tours, heritage routes, transport help, and safety-aware travel planning."
  image="/images/your-mali-guides-og.jpg"
  additionalSchema={faqSchema}
>

  <!-- ============ HERO ============ -->
  <section style="position:relative;min-height:clamp(34rem,78vh,52rem);display:grid;align-items:center;">
    <div style="position:absolute;inset:0;overflow:hidden;">
      <picture>
        <source srcset="/images/hero-home.webp" type="image/webp" />
        <img
          src="/images/hero-home.jpg"
          alt="West African landscape and culture"
          width="3152" height="1545"
          fetchpriority="high"
          decoding="async"
          style="width:100%;height:100%;object-fit:cover;object-position:center 40%;"
        />
      </picture>
      <div style="position:absolute;inset:0;background:var(--overlay-hero);"></div>
      <div style="position:absolute;inset:0;background:linear-gradient(96deg, rgba(21,32,29,0.66) 0%, rgba(21,32,29,0.24) 46%, rgba(21,32,29,0) 80%);"></div>
    </div>
    <div style="position:relative;width:100%;max-width:var(--content-max);margin:0 auto;padding:clamp(2rem,6vw,4rem) var(--gutter);">
      <div class="hero-glass-card" style="max-width:640px;">
        <p class="eyebrow-gold" style="margin-bottom:22px;color:rgba(31,76,59,0.9);">Mali · West Africa · Private guiding</p>
        <h1 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.025em;line-height:0.99;font-size:clamp(2.2rem,4.5vw,3.8rem);color:var(--ink);margin:0 0 20px;text-wrap:balance;">
          Travel the real Mali and West Africa, with someone who lives it
        </h1>
        <p style="font-family:var(--font-serif);font-size:clamp(1rem,1.3vw,1.18rem);line-height:1.65;color:var(--text-body);margin:0 0 28px;">
          Plan a realistic private trip with <strong style="font-weight:600;color:var(--ink);">Djibril Kassogue</strong> — an official local guide who helps travellers with Bamako, heritage routes, cultural context, transport, and safety-aware planning.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:28px;">
          <a href={waMain} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:9px;font-family:var(--font-ui);font-weight:600;font-size:15px;background:var(--clay);color:var(--cream);padding:14px 24px;border-radius:10px;text-decoration:none;box-shadow:0 4px 16px rgba(184,88,50,0.28);">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8 0-1.3.7-2 .9-2.2.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2 .8.6 1.4.8 1.7 1 .2.1.4.1.5-.1l.7-.8c.2-.2.3-.2.6-.1l1.8.9c.3.1.4.2.5.3.1.2.1.9-.1 1.6Z"/></svg>
            Message Djibril on WhatsApp
          </a>
          <a href="/tours/" style="display:inline-flex;align-items:center;gap:8px;font-family:var(--font-ui);font-weight:600;font-size:15px;background:rgba(21,32,29,0.07);color:var(--ink);padding:14px 22px;border-radius:10px;text-decoration:none;border:1px solid rgba(21,32,29,0.15);">
            See Mali tour ideas →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FLOATING FIRST-MESSAGE PANEL ============ -->
  <section style="position:relative;background:var(--cream);padding-bottom:clamp(4rem,8vw,6.5rem);">
    <div class="container-site">
      <div class="first-msg-card">
        <div>
          <p class="eyebrow" style="margin-bottom:14px;">Your first message</p>
          <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.015em;line-height:1.08;font-size:clamp(1.7rem,2.6vw,2.4rem);color:var(--ink);margin:0 0 16px;">
            You do not need a finished itinerary
          </h2>
          <p style="font-family:var(--font-serif);font-size:1.08rem;line-height:1.65;color:var(--text-body);margin:0 0 26px;max-width:42ch;">
            Send a few practical details on WhatsApp and Djibril will tell you what is realistic, what may need adjusting, and how to plan it responsibly.
          </p>
          <a href={waMain} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:9px;font-family:var(--font-ui);font-weight:600;font-size:14.5px;background:var(--clay);color:var(--cream);padding:13px 22px;border-radius:10px;text-decoration:none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8 0-1.3.7-2 .9-2.2.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2 .8.6 1.4.8 1.7 1 .2.1.4.1.5-.1l.7-.8c.2-.2.3-.2.6-.1l1.8.9c.3.1.4.2.5.3.1.2.1.9-.1 1.6Z"/></svg>
            Message Djibril with these details
          </a>
        </div>
        <div style="background:var(--tag-bg);border:1px solid var(--sand);border-radius:14px;padding:26px 28px;">
          <p style="font-family:var(--font-ui);font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin:0 0 16px;">What to send</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px 20px;">
            {checklist.map((item) => (
              <div style="display:flex;align-items:flex-start;gap:9px;font-family:var(--font-serif);font-size:0.98rem;color:var(--text-body);">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--forest)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FEATURED ROUTES ============ -->
  <section style="background:var(--cream);padding:clamp(4rem,8vw,6.5rem) 0;" id="routes">
    <div class="container-site">
      <div style="border-top:1px solid var(--sand);padding-top:34px;margin-bottom:46px;max-width:760px;">
        <p class="eyebrow" style="margin-bottom:18px;">Featured routes</p>
        <h2 class="section-h2" style="margin-bottom:16px;">Private Mali trips, planned around real conditions</h2>
        <p style="font-family:var(--font-serif);font-size:1.1rem;line-height:1.65;color:var(--text-muted);margin:0;max-width:60ch;">
          Choose a starting idea, then message Djibril to shape the route around your dates, budget, pace, and what is realistic right now.
        </p>
      </div>
      <div class="routes-grid">
        {routes.map((r) => (
          <div class="route-card">
            <div style="position:relative;aspect-ratio:3/2;overflow:hidden;">
              <img src={r.image} alt={r.alt} width="540" height="360" loading="lazy" class="route-img" />
              <div style="position:absolute;inset:0;background:var(--overlay-image-top);"></div>
              <span style={`position:absolute;top:13px;left:13px;font-family:var(--font-ui);font-size:11.5px;font-weight:600;color:var(--cream);background:${r.feasColor};padding:5px 11px;border-radius:999px;backdrop-filter:blur(3px);`}>{r.feasibility}</span>
            </div>
            <div style="padding:22px 22px 24px;display:flex;flex-direction:column;flex:1;">
              <h3 style="font-family:var(--font-display);font-weight:600;font-size:1.4rem;letter-spacing:-0.01em;color:var(--ink);margin:0 0 10px;">{r.title}</h3>
              <p style="font-family:var(--font-serif);font-size:0.97rem;line-height:1.55;color:var(--text-body);margin:0 0 6px;">
                <span style="color:var(--clay-text);font-weight:600;">Best for </span>{r.bestFor}
              </p>
              <p style="font-family:var(--font-serif);font-size:0.97rem;line-height:1.55;color:var(--text-muted);margin:0 0 auto;">{r.note}</p>
              <div style="display:flex;align-items:center;gap:14px;padding-top:16px;margin-top:18px;border-top:1px solid var(--sand);">
                <a href={waRoute(r.topic)} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;font-family:var(--font-ui);font-weight:600;font-size:13.5px;color:var(--clay-text);text-decoration:none;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8 0-1.3.7-2 .9-2.2.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2 .8.6 1.4.8 1.7 1 .2.1.4.1.5-.1l.7-.8c.2-.2.3-.2.6-.1l1.8.9c.3.1.4.2.5.3.1.2.1.9-.1 1.6Z"/></svg>
                  Ask on WhatsApp
                </a>
                <a href={r.ideaUrl} style="font-family:var(--font-ui);font-weight:500;font-size:13.5px;color:var(--text-muted);text-decoration:none;margin-left:auto;">Route idea →</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ WHY DJIBRIL ============ -->
  <section style="background:#fff;border-top:1px solid var(--sand);border-bottom:1px solid var(--sand);padding:clamp(4rem,8vw,6.5rem) 0;">
    <div class="container-site">
      <div style="margin-bottom:48px;max-width:720px;">
        <p class="eyebrow" style="margin-bottom:18px;">Why travel with Djibril</p>
        <h2 class="section-h2">Trust, context, and real help from the ground</h2>
      </div>
      <div class="reasons-grid">
        {reasons.map((r) => (
          <div class="reason-cell">
            <div style="width:46px;height:46px;border-radius:50%;background:rgba(31,76,59,0.08);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--forest)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3 style="font-family:var(--font-display);font-weight:600;font-size:1.3rem;letter-spacing:-0.01em;color:var(--ink);margin:0 0 10px;">{r.title}</h3>
            <p style="font-family:var(--font-serif);font-size:0.97rem;line-height:1.65;color:var(--text-muted);margin:0;">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ ABOUT / MEET YOUR GUIDE ============ -->
  <section style="background:var(--cream);padding:clamp(4rem,8vw,6.5rem) 0;">
    <div class="container-site about-grid">
      <div style="position:relative;display:grid;grid-template-rows:auto auto;gap:14px;">
        <div class="image-card" style="aspect-ratio:4/5;overflow:hidden;">
          <img
            src="/images/djibril-kassogue-portrait.webp"
            alt="Djibril Kassogue, official local guide in Mali"
            width="720" height="900"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          />
        </div>
        <div class="image-card" style="aspect-ratio:3/2;overflow:hidden;">
          <picture>
            <source srcset="/images/traveller-guide-bamako.webp" type="image/webp" />
            <img
              src="/images/traveller-guide-bamako.jpg"
              alt="Traveller with a local guide in Bamako, Mali"
              width="2077" height="1562"
              loading="lazy"
              style="width:100%;height:100%;object-fit:cover;object-position:center 30%;"
            />
          </picture>
        </div>
        <div style="position:absolute;top:20px;right:-12px;background:white;border-radius:12px;padding:14px 18px;box-shadow:var(--shadow-hero-card);display:flex;align-items:center;gap:12px;max-width:220px;">
          <div style="width:36px;height:36px;border-radius:50%;background:rgba(31,76,59,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <p style="font-family:var(--font-ui);font-size:0.78rem;font-weight:600;color:var(--ink);margin:0;line-height:1.4;">Official registered local guide, Mali</p>
        </div>
      </div>
      <div>
        <p class="eyebrow" style="margin-bottom:18px;">Meet your guide</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.018em;line-height:1.06;font-size:clamp(2rem,3.4vw,3rem);color:var(--ink);margin:0 0 22px;">Djibril Kassogue</h2>
        <p style="font-family:var(--font-serif);font-size:1.1rem;line-height:1.7;color:var(--text-body);margin:0 0 16px;">
          Djibril is an official, registered local guide based in Mali, with years of experience helping travellers plan realistic and responsible private trips across the country and wider West Africa.
        </p>
        <p style="font-family:var(--font-serif);font-size:1.1rem;line-height:1.7;color:var(--text-body);margin:0 0 28px;">
          He speaks French, English, and local Malian languages, and brings genuine on-the-ground knowledge to every trip — from Bamako city culture to the heritage towns of Djenné and Mopti and selected routes beyond.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;">
          {aboutTags.map((tag) => (
            <span style="font-family:var(--font-ui);font-size:0.85rem;font-weight:600;color:var(--clay-text);background:var(--tag-bg);border:1px solid var(--sand);border-radius:999px;padding:7px 16px;">{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ HOW PLANNING WORKS (DARK) ============ -->
