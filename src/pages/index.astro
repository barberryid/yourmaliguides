---
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import TourCard from "@components/TourCard.astro";
import CTASection from "@components/CTASection.astro";
import WhatsAppLink from "@components/WhatsAppLink.astro";
import { images } from "@data/images";
import { features, tours, trustBadges } from "@data/content";
---

<BaseLayout>
  <section class="relative min-h-[86vh] overflow-hidden bg-indigo-deep text-white">
    <img src={images.hero} alt="Niger River and Mali travel landscape" class="absolute inset-0 h-full w-full object-cover opacity-70" />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(12,20,45,.88),rgba(12,20,45,.52),rgba(12,20,45,.18))]"></div>
    <div class="container-site relative grid min-h-[86vh] content-center py-20">
      <div class="max-w-4xl">
        <p class="eyebrow text-sahel-sand">Official local guide in Mali</p>
        <h1 class="display-title mt-5 text-balance text-5xl md:text-7xl">Explore Mali with Djibril Kassogue</h1>
        <p class="mt-6 max-w-3xl text-xl leading-9 text-white/86">
          Official local guide for Mali and West Africa - custom trips, cultural journeys, desert routes, Dogon Country, Djenne, Timbuktu, Bamako, and beyond.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <WhatsAppLink label="WhatsApp Djibril Now" className="btn btn-whatsapp" />
          <a href="/tours/" class="btn btn-outline border-white/25 bg-white/12 text-white hover:bg-white/20">Explore Mali Tours</a>
        </div>
        <p class="mt-4 text-sm font-semibold text-sahel-sand">Fastest response: send your dates, number of travellers, and places you want to visit.</p>
        <div class="mt-10 flex flex-wrap gap-3">
          {trustBadges.map((badge) => <span class="rounded-full border border-white/20 bg-white/12 px-4 py-2 text-sm font-bold backdrop-blur">{badge}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-cream">
    <div class="container-site grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="image-card">
        <img src={images.portrait} alt="Djibril Kassogue official guide in Mali" class="h-[520px] w-full object-cover" />
      </div>
      <div>
        <SectionHeading eyebrow="Meet your guide" title="Local knowledge changes the whole trip." text="Djibril Kassogue helps travellers explore Mali with practical confidence: route planning, local interpretation, transport support, cultural access, negotiation help, and safety-aware logistics." />
        <p class="mt-6 leading-8 text-slate-700">
          Whether you want a short Bamako introduction, a custom Mali route, or selected West Africa planning, Djibril starts with your dates, interests, group size, and what is realistic under current conditions.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/about/" class="btn btn-indigo">About Djibril</a>
          <a href="/reviews/" class="btn btn-outline">See Reviews</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-site">
      <SectionHeading eyebrow="Featured routes" title="Private Mali trips, planned around real conditions." text="Choose a starting idea, then message Djibril on WhatsApp to shape the route around your dates, budget, pace, and safety considerations." />
      <div class="mt-10 grid gap-7 md:grid-cols-2 lg:grid-cols-3">
        {tours.map((tour) => <TourCard tour={tour} />)}
      </div>
    </div>
  </section>

  <section class="section-pad pattern">
    <div class="container-site">
      <SectionHeading eyebrow="Why travel with Djibril" title="Trust, context, and practical help from the ground." align="center" />
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {features.map((feature) => (
          <article class="rounded-lg border border-slate-900/10 bg-white/88 p-6 shadow-lg backdrop-blur">
            <h3 class="font-serif text-2xl font-extrabold text-indigo-deep">{feature.title}</h3>
            <p class="mt-3 leading-7 text-slate-700">{feature.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-cream">
    <div class="container-site grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <SectionHeading eyebrow="How planning works" title="Three simple steps to a custom trip." text="No complicated form. Send a clear WhatsApp message and Djibril can help turn your interests into a safe and realistic itinerary." />
      <div class="grid gap-4">
        {["Send a WhatsApp message", "Share dates, group size, language, and interests", "Djibril helps design the route"].map((step, index) => (
          <div class="flex gap-4 rounded-lg bg-white p-5 shadow-md">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-clay font-bold text-white">{index + 1}</span>
            <p class="self-center text-lg font-bold text-indigo-deep">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <SectionHeading eyebrow="Photo story" title="A real look at Mali, people, routes, and culture." />
        <a href="/photos/" class="btn btn-outline self-start md:self-auto">View Gallery</a>
      </div>
      <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-4">
        {images.gallery.slice(0, 8).map((image, index) => (
          <img src={image.src} alt={image.alt} loading="lazy" class:list={["h-56 w-full rounded-lg object-cover shadow-md", index === 0 && "md:col-span-2 md:row-span-2 md:h-full"]} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-cream">
    <div class="container-site grid gap-8 md:grid-cols-2">
      <article class="rounded-lg bg-indigo-deep p-8 text-white shadow-xl">
        <p class="eyebrow text-sahel-sand">References</p>
        <h2 class="display-title mt-3 text-4xl">Recommended by experienced travellers.</h2>
        <p class="mt-5 leading-8 text-white/78">Ask Djibril for recent references and traveller feedback before you plan. Public review text has not been invented here.</p>
        <a href="/reviews/" class="btn btn-whatsapp mt-7">Ask for references</a>
      </article>
      <article class="rounded-lg bg-white p-8 shadow-xl">
        <p class="eyebrow">Community</p>
        <h2 class="display-title mt-3 text-4xl text-indigo-deep">Travel connected to local life.</h2>
        <p class="mt-5 leading-8 text-slate-700">Djibril can help travellers understand local communities, visit respectfully, and ask about current community projects or ways to support local people.</p>
        <a href="/community-projects/" class="btn btn-indigo mt-7">Community Projects</a>
      </article>
    </div>
  </section>

  <CTASection />
</BaseLayout>
