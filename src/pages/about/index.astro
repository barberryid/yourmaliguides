---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import FinalCTA from "@components/FinalCTA.astro";
import { features } from "@data/content";
import { images } from "@data/images";

const credentials = [
  { label: "Languages", value: "French, English, Bambara, Fulani" },
  { label: "Registration", value: "Official registered guide, Mali" },
  { label: "Regions", value: "Mali, Burkina Faso, West Africa" },
  { label: "Speciality", value: "Cultural routes, heritage towns, custom trips" },
];

const aboutTags = [
  "Speaks local languages",
  "Trusted local contacts",
  "Years of guiding",
  "West Africa network",
];
---

<BaseLayout
  title="About Djibril Kassogue | Your Mali Guides"
  description="Meet Djibril Kassogue, an official registered guide in Mali for custom private trips, cultural tours, and West Africa route planning."
>
  <PageHero
    image={images.portrait}
    alt="Djibril Kassogue, official local guide in Mali"
    eyebrow="Meet your guide"
    title="Djibril Kassogue"
    lead="Official registered guide in Mali, helping travellers plan realistic private trips with genuine local knowledge and safety-aware route planning."
    waTopic=""
    waLabel="Message Djibril on WhatsApp"
    imagePosition="center 20%"
    minHeight="68vh"
  />

  <!-- About story -->
  <section style="background:var(--cream);padding:clamp(4rem,8vw,6.5rem) 0;">
    <div class="container-site" style="display:grid;grid-template-columns:0.9fr 1.1fr;gap:clamp(36px,5vw,72px);align-items:start;">

      <!-- Portrait with badge -->
      <div style="position:relative;">
        <div class="image-card" style="aspect-ratio:4/5;overflow:hidden;">
          <img
            src={images.portrait}
            alt="Djibril Kassogue, Mali guide"
            width="720" height="900"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;object-position:center 20%;"
          />
        </div>
        <div style="position:absolute;bottom:20px;right:-12px;background:white;border-radius:12px;padding:14px 18px;box-shadow:var(--shadow-hero-card);display:flex;align-items:center;gap:12px;max-width:220px;">
          <div style="width:36px;height:36px;border-radius:50%;background:rgba(31,76,59,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <p style="font-family:var(--font-ui);font-size:0.78rem;font-weight:600;color:var(--ink);margin:0;line-height:1.4;">Official registered local guide, Mali</p>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:20px;">
          {aboutTags.map((tag) => (
            <span style="font-family:var(--font-ui);font-size:0.83rem;font-weight:600;color:var(--clay-text);background:var(--tag-bg);border:1px solid var(--sand);border-radius:999px;padding:6px 14px;">{tag}</span>
          ))}
        </div>
      </div>

      <!-- Prose -->
      <div>
        <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:0.75rem;color:var(--clay-text);margin:0 0 18px;">Guide story</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.015em;line-height:1.06;font-size:clamp(2rem,3.4vw,3rem);color:var(--ink);margin:0 0 28px;">A local guide for deeper, easier travel</h2>

        <div style="font-family:var(--font-serif);font-size:1.12rem;line-height:1.75;color:var(--text-body);">
          <p style="margin:0 0 20px;max-width:64ch;">Djibril helps visitors understand Mali through real local context: people, routes, markets, architecture, music, history, food, and daily life. He builds custom itineraries around each traveller's interests rather than forcing every visitor into the same plan.</p>

          <p style="margin:0 0 20px;max-width:64ch;">His work includes route planning, transport coordination, cultural interpretation, negotiation help, local contacts, and safety-aware logistics. Travellers can share the places they hope to visit, then Djibril advises what is practical and responsible under current conditions.</p>

          <!-- Pull quote -->
          <blockquote style="border-left:2px solid var(--clay);margin:28px 0;padding:16px 20px;background:var(--tag-bg);border-radius:0 12px 12px 0;">
            <p style="font-family:var(--font-serif);font-size:1.08rem;line-height:1.65;color:var(--ink);font-style:italic;margin:0;">Djibril peut organiser des circuits personnalisés au Mali et en Afrique de l'Ouest. Envoyez vos dates, le nombre de voyageurs et les lieux que vous souhaitez visiter par WhatsApp.</p>
          </blockquote>

          <p style="margin:0;max-width:64ch;">He is patient, honest, and careful about not over-promising what is accessible. If a route is not realistic under current conditions, he will say so and suggest what is.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials / facts strip -->
  <section style="background:#fff;border-top:1px solid var(--sand);border-bottom:1px solid var(--sand);padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container-site">
      <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:0.75rem;color:var(--clay-text);margin:0 0 32px;">Credentials and background</p>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;">
        {credentials.map((c) => (
          <div style="border-top:2px solid var(--sand);padding-top:18px;">
            <p style="font-family:var(--font-ui);font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-muted);margin:0 0 8px;">{c.label}</p>
            <p style="font-family:var(--font-display);font-weight:600;font-size:1.05rem;color:var(--ink);margin:0;line-height:1.35;">{c.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why travel with Djibril -->
  <section style="background:var(--cream);padding:clamp(4rem,8vw,6.5rem) 0;">
    <div class="container-site">
      <div style="margin-bottom:40px;max-width:620px;">
        <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:0.75rem;color:var(--clay-text);margin:0 0 16px;">Why travel with Djibril</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.015em;line-height:1.06;font-size:clamp(2rem,3.4vw,3rem);color:var(--ink);margin:0;">Trust, context, and real help from the ground</h2>
      </div>
      <div class="reasons-grid">
        {features.map((f) => (
          <div class="reason-cell">
            <div style="width:46px;height:46px;border-radius:50%;background:rgba(31,76,59,0.08);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--forest)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3 style="font-family:var(--font-display);font-weight:600;font-size:1.25rem;color:var(--ink);margin:0 0 10px;">{f.title}</h3>
            <p style="font-family:var(--font-serif);font-size:0.97rem;line-height:1.65;color:var(--text-muted);margin:0;">{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA title="Plan a trip with Djibril" lead="Message him on WhatsApp with your dates, group size, and the places you hope to visit." />

</BaseLayout>

<style>
  @media (max-width: 767px) {
    .container-site > div[style*="grid-template-columns:0.9fr"] {
      grid-template-columns: 1fr !important;
    }
    .container-site > div[style*="grid-template-columns:repeat(4"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>
