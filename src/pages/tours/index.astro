---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import RouteCard from "@components/RouteCard.astro";
import FinalCTA from "@components/FinalCTA.astro";
import { routes, planningSteps, safetyPoints } from "@data/content";
import { images } from "@data/images";

const faqs = [
  {
    q: "How do I choose which Mali route is right for me?",
    a: "Share your dates, interests, and budget with Djibril. He can advise which routes are realistic right now and help you choose based on conditions, not just wish lists.",
  },
  {
    q: "Can routes change after we agree a plan?",
    a: "Yes. Mali conditions can shift. Djibril will always tell you honestly if a route needs adjustment and suggest the best alternative available at the time.",
  },
  {
    q: "How long in advance should I contact Djibril?",
    a: "As early as possible is helpful, particularly for longer or multi-destination trips. For Bamako visits, shorter notice can sometimes work. Send your dates and let him advise.",
  },
  {
    q: "Are the routes fixed or can they be customised?",
    a: "All routes are private and custom. The cards on this page are starting ideas — send your interests and Djibril will shape the actual itinerary around your specific trip.",
  },
  {
    q: "What is included in the guide fee?",
    a: "Djibril's guiding, cultural interpretation, route advice, local contacts, and safety-aware logistics. Transport, accommodation, and entry fees are separate — he can advise on costs.",
  },
];
---

<BaseLayout
  title="Mali Tours with a Local Guide | Your Mali Guides"
  description="Plan Bamako, Djenné, Mopti, Dogon Country, Timbuktu, and custom Mali routes with Djibril Kassogue, an official local guide."
>
  <PageHero
    image={images.dogon}
    alt="Dogon Country landscape and traditional villages in Mali"
    eyebrow="Mali tours"
    title="Private Mali trips, planned around real conditions"
    lead="These are starting ideas for private trips. Routes depend on current conditions, safety, timing, transport, and what is practically feasible when you travel."
    waTopic="a private Mali tour"
    waLabel="Ask about a Mali route"
    secondaryHref="#routes"
    secondaryLabel="See all routes ↓"
  />

  <!-- Route cards -->
  <section style="background:var(--cream);padding:clamp(4rem,8vw,6.5rem) 0;" id="routes">
    <div class="container-site">
      <div style="border-top:1px solid var(--sand);padding-top:34px;margin-bottom:46px;max-width:760px;">
        <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:12px;color:var(--clay-text);margin:0 0 18px;">Featured routes</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.018em;line-height:1.06;font-size:clamp(2rem,3.4vw,3rem);color:var(--ink);margin:0 0 16px;">Six routes to start the conversation</h2>
        <p style="font-family:var(--font-serif);font-size:1.1rem;line-height:1.65;color:var(--text-muted);margin:0;max-width:60ch;">Choose a starting idea, then contact Djibril to shape the route around your dates, budget, pace, and what is realistic right now.</p>
      </div>
      <div class="routes-grid">
        {routes.map((r) => <RouteCard route={r} />)}
      </div>
    </div>
  </section>

  <!-- Route details -->
  <section style="background:#fff;border-top:1px solid var(--sand);padding:clamp(4rem,8vw,6.5rem) 0;">
    <div class="container-site">
      <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:12px;color:var(--clay-text);margin:0 0 32px;">Route notes</p>
      <div style="display:grid;gap:16px;">
        {[
          { id: "bamako", title: "Bamako", text: "Markets, culture, music, food, city orientation, museums, neighbourhood life, and arrival logistics. A good standalone visit or a practical first step before travelling further." },
          { id: "djenne-mopti", title: "Djenné and Mopti", text: "Historic mud architecture, river culture, local life, and practical route planning through central Mali. Advised only when current conditions make the route realistic." },
          { id: "dogon", title: "Dogon Country", text: "Villages, cliffs, architecture, and cultural interpretation when current local conditions allow. Dogon routes are assessed case by case and are never promised blindly." },
          { id: "timbuktu", title: "Timbuktu and the Desert Routes", text: "Historic city, manuscripts, desert heritage, and northern travel. Only when conditions, transport, and access are realistic — always checked before plans are confirmed." },
          { id: "custom", title: "Custom Mali Route", text: "A route built around your dates, interests, budget, language, and the practical support you need. Start by sending your rough idea on WhatsApp." },
        ].map(({ id, title, text }) => (
          <article id={id} style="scroll-margin-top:100px;background:var(--cream);border:1px solid var(--sand);border-radius:16px;padding:clamp(20px,3vw,32px);" class="card-hover">
            <h2 style="font-family:var(--font-display);font-weight:600;font-size:1.5rem;color:var(--ink);margin:0 0 10px;">{title}</h2>
            <p style="font-family:var(--font-serif);font-size:1rem;line-height:1.7;color:var(--text-body);margin:0 0 6px;">{text}</p>
            <p style="font-family:var(--font-serif);font-size:0.93rem;color:var(--clay-text);font-weight:600;margin:0;">Routes depend on current conditions, safety advice, timing, and local feasibility.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- How planning works (dark band) -->
  <section style="position:relative;background:var(--ink);padding:clamp(4rem,8vw,6.5rem) 0;overflow:hidden;">
    <div style="position:absolute;inset:0;">
      <img src="/images/plantation-walk.jpg" alt="" aria-hidden="true" width="1600" height="900" loading="lazy" style="width:100%;height:100%;object-fit:cover;opacity:0.14;" />
    </div>
    <div class="container-site" style="position:relative;">
      <div style="margin-bottom:52px;max-width:680px;">
        <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:12px;color:var(--gold);margin:0 0 18px;">How planning works</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.018em;line-height:1.06;font-size:clamp(2rem,3.4vw,3rem);color:var(--cream);margin:0;">Three simple steps to a custom trip</h2>
      </div>
      <div class="steps-grid">
        {planningSteps.map((s) => (
          <div style="border-top:2px solid rgba(196,154,58,0.55);padding-top:24px;">
            <div style="font-family:var(--font-display);font-weight:600;font-size:3rem;color:var(--gold);line-height:1;margin-bottom:16px;">{s.n}</div>
            <p style="font-family:var(--font-serif);font-size:1.1rem;line-height:1.65;color:rgba(244,239,228,0.9);margin:0;">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Safety -->
  <section style="background:#fff;border-top:1px solid var(--sand);padding:clamp(4rem,8vw,6.5rem) 0;">
    <div class="container-site safety-grid">
      <div>
        <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:0.75rem;color:var(--clay-text);margin:0 0 18px;">Safety-aware planning</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.015em;line-height:1.06;font-size:clamp(2rem,3.4vw,3rem);color:var(--ink);margin:0 0 18px;">Safety and feasibility come first</h2>
        <p style="font-family:var(--font-serif);font-size:1.1rem;line-height:1.7;color:var(--text-body);margin:0 0 28px;">Mali travel can change quickly. Djibril does not promise routes blindly. He will advise what is realistic based on current local conditions, transport, timing, and safety.</p>
        <a href="/contact/" style="display:inline-flex;align-items:center;font-family:var(--font-ui);font-weight:600;font-size:14.5px;background:var(--clay);color:var(--cream);padding:13px 22px;border-radius:10px;text-decoration:none;">
          Contact Djibril →
        </a>
      </div>
      <div style="background:var(--tag-bg);border:1px solid var(--sand);border-radius:14px;padding:clamp(22px,3vw,36px);">
        <p style="font-family:var(--font-ui);font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);margin:0 0 20px;">How routes are judged</p>
        <div style="display:grid;gap:18px;">
          {safetyPoints.map((sp) => (
            <div style="display:flex;align-items:flex-start;gap:14px;">
              <div style="width:34px;height:34px;border-radius:50%;background:rgba(31,76,59,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--forest)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <p style="font-family:var(--font-display);font-weight:600;font-size:1.05rem;color:var(--ink);margin:0 0 4px;">{sp.title}</p>
                <p style="font-family:var(--font-serif);font-size:0.95rem;line-height:1.6;color:var(--text-muted);margin:0;">{sp.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background:var(--cream);padding:clamp(4rem,8vw,6.5rem) 0;" id="faq">
    <div class="container-site" style="max-width:780px;">
      <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:0.75rem;color:var(--clay-text);margin:0 0 18px;">Common questions</p>
      <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.015em;line-height:1.06;font-size:clamp(2rem,3.4vw,3rem);color:var(--ink);margin:0 0 40px;">Logistics and route questions</h2>
      <div style="display:grid;gap:10px;" id="faq-list">
        {faqs.map((faq, i) => (
          <div class={`faq-item${i === 0 ? " open" : ""}`} data-faq={i}>
            <button class="faq-btn" type="button" aria-expanded={i === 0 ? "true" : "false"}>
              <span>{faq.q}</span>
              <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-body">
              <div class="faq-body-inner">{faq.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA title="Plan a Mali route with Djibril" lead="Send your dates, group size, and the places you hope to visit. He can advise what is realistic right now." />

</BaseLayout>

<style>
  .routes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(28px, 4vw, 48px);
  }
  .safety-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(36px, 5vw, 72px);
    align-items: start;
  }
  .card-hover {
    transition: box-shadow 180ms ease, transform 180ms ease;
  }
  .card-hover:hover {
    box-shadow: var(--shadow-raised);
    transform: translateY(-2px);
  }
  @media (max-width: 900px) {
    .routes-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .routes-grid { grid-template-columns: 1fr; }
    .safety-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const faqItems = document.querySelectorAll(".faq-item");
  faqItems.forEach((item) => {
    const btn = item.querySelector(".faq-btn");
    btn?.addEventListener("click", () => {
      const isOpen = item.classList.contains("open");
      faqItems.forEach((el) => {
        el.classList.remove("open");
        el.querySelector(".faq-btn")?.setAttribute("aria-expanded", "false");
      });
      if (!isOpen) {
        item.classList.add("open");
        btn.setAttribute("aria-expanded", "true");
      }
    });
  });
</script>
