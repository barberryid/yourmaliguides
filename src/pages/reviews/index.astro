---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import FinalCTA from "@components/FinalCTA.astro";
import { images } from "@data/images";

const trustPoints = [
  {
    title: "Official registration",
    body: "Djibril is an officially registered guide in Mali. This can be confirmed on request.",
  },
  {
    title: "References on request",
    body: "Djibril can share recent references and feedback from experienced travellers with similar plans. Ask him directly on WhatsApp.",
  },
  {
    title: "Honest about conditions",
    body: "Travellers consistently note that Djibril is straightforward about what is and isn't realistic — he does not over-promise routes.",
  },
  {
    title: "No fabricated reviews",
    body: "No invented testimonials are published here. Private names and feedback are not shared without permission.",
  },
];

const steps = [
  { n: "1", title: "Ask for recent references", body: "Message Djibril on WhatsApp with your planned route and dates. Ask for feedback from travellers who made similar trips." },
  { n: "2", title: "Share your route idea", body: "Tell Djibril your destinations and interests. He can connect you with previous travellers who visited the same places." },
  { n: "3", title: "Confirm practical details", body: "Once you have references and a clear picture, you can confirm dates, logistics, and what is realistic for your trip." },
];
---

<BaseLayout
  title="Reviews and References | Your Mali Guides"
  description="Ask Djibril Kassogue for recent traveller references and feedback for Mali and West Africa guide services. Honest reviews available on request."
>
  <PageHero
    image={images.about}
    alt="Djibril Kassogue with a traveller on a Mali guiding trip"
    eyebrow="What travellers say"
    title="References available on request"
    lead="Djibril does not publish fabricated review text. He can share real references from recent travellers on WhatsApp — ask him directly."
    waTopic="recent traveller references"
    waLabel="Ask for recent references"
    minHeight="58vh"
  />

  <!-- Trust points -->
  <section style="background:var(--cream);padding:clamp(4rem,8vw,6.5rem) 0;">
    <div class="container-site">
      <div style="margin-bottom:48px;max-width:680px;">
        <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:0.75rem;color:var(--clay-text);margin:0 0 18px;">Why references matter</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.015em;line-height:1.06;font-size:clamp(2rem,3.4vw,3rem);color:var(--ink);margin:0;">An honest approach to trust</h2>
      </div>
      <div class="reasons-grid">
        {trustPoints.map((tp) => (
          <div class="reason-cell">
            <div style="width:46px;height:46px;border-radius:50%;background:rgba(31,76,59,0.08);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--forest)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            </div>
            <h3 style="font-family:var(--font-display);font-weight:600;font-size:1.25rem;color:var(--ink);margin:0 0 10px;">{tp.title}</h3>
            <p style="font-family:var(--font-serif);font-size:0.97rem;line-height:1.65;color:var(--text-muted);margin:0;">{tp.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How to get references -->
  <section style="position:relative;background:var(--ink);padding:clamp(4rem,8vw,6.5rem) 0;overflow:hidden;">
    <div style="position:absolute;inset:0;">
      <img src="/images/plantation-walk.jpg" alt="" aria-hidden="true" width="1600" height="900" loading="lazy" style="width:100%;height:100%;object-fit:cover;opacity:0.14;" />
    </div>
    <div class="container-site" style="position:relative;">
      <div style="margin-bottom:52px;max-width:680px;">
        <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:12px;color:var(--gold);margin:0 0 18px;">How it works</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.018em;line-height:1.06;font-size:clamp(2rem,3.4vw,3rem);color:var(--cream);margin:0;">Three steps to finding the right guide</h2>
      </div>
      <div class="steps-grid">
        {steps.map((s) => (
          <div style="border-top:2px solid rgba(196,154,58,0.55);padding-top:24px;">
            <div style="font-family:var(--font-display);font-weight:600;font-size:3rem;color:var(--gold);line-height:1;margin-bottom:16px;">{s.n}</div>
            <h3 style="font-family:var(--font-display);font-weight:600;font-size:1.2rem;color:var(--cream);margin:0 0 10px;">{s.title}</h3>
            <p style="font-family:var(--font-serif);font-size:1rem;line-height:1.65;color:rgba(244,239,228,0.85);margin:0;">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section style="background:#fff;border-top:1px solid var(--sand);padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container-site" style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(28px,4vw,56px);align-items:center;">
      <div>
        <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:0.75rem;color:var(--clay-text);margin:0 0 18px;">References and trust</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.015em;line-height:1.06;font-size:clamp(1.8rem,3vw,2.6rem);color:var(--ink);margin:0 0 18px;">Ask Djibril directly</h2>
        <p style="font-family:var(--font-serif);font-size:1.05rem;line-height:1.7;color:var(--text-body);margin:0 0 24px;">The most direct and honest way to evaluate a guide is to ask him for references from travellers who made similar trips. Djibril is happy to provide these on WhatsApp.</p>
        <a href={`https://wa.me/22374482693?text=${encodeURIComponent("Hello Djibril, I am considering a trip to Mali. Could you share references from recent travellers with similar plans? My route of interest is: ___.") }`} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:9px;font-family:var(--font-ui);font-weight:600;font-size:14.5px;background:var(--clay);color:var(--cream);padding:13px 22px;border-radius:10px;text-decoration:none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8 0-1.3.7-2 .9-2.2.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2 .8.6 1.4.8 1.7 1 .2.1.4.1.5-.1l.7-.8c.2-.2.3-.2.6-.1l1.8.9c.3.1.4.2.5.3.1.2.1.9-.1 1.6Z"/></svg>
          Ask for recent references
        </a>
      </div>
      <div class="image-card" style="aspect-ratio:4/3;overflow:hidden;">
        <img src={images.portrait} alt="Djibril Kassogue, Mali guide" width="720" height="540" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:center 20%;" />
      </div>
    </div>
  </section>

  <FinalCTA
    title="Ready to plan a Mali trip?"
    lead="Ask for references, share your route idea, and let Djibril help you plan something realistic and worthwhile."
    waLabel="Message Djibril on WhatsApp"
  />

</BaseLayout>

<style>
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(28px, 4vw, 48px);
  }
  @media (max-width: 767px) {
    .steps-grid { grid-template-columns: 1fr; }
    .container-site > div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
