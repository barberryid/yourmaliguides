---
import BaseLayout from "@layouts/BaseLayout.astro";
import FinalCTA from "@components/FinalCTA.astro";
import { site } from "@config/site";

const waMain = `${site.whatsappUrl}?text=${encodeURIComponent(site.whatsappMessage)}`;

const checklist = [
  "Your travel dates",
  "Number of travellers",
  "Arrival city",
  "Places you hope to visit",
  "Preferred language",
  "Budget level",
  "Travel pace",
  "Any safety concerns",
];

const contactLinks = [
  { label: `WhatsApp: +${site.whatsappNumber}`, href: waMain },
  { label: "Facebook: Djibril Kassogue", href: site.facebookUrl },
  { label: "Instagram: @djibril_kassogue", href: site.instagramUrl },
];
---

<BaseLayout
  title="Contact Djibril Kassogue | Your Mali Guides"
  description="Contact Djibril Kassogue on WhatsApp to plan a private Mali trip with practical route advice, transport help, and safety-aware planning."
>

  <!-- Page header -->
  <section style="background:var(--cream);padding:clamp(4rem,8vw,6.5rem) 0 0;">
    <div class="container-site" style="max-width:780px;">
      <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:0.75rem;color:var(--clay-text);margin:0 0 18px;">Contact</p>
      <h1 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.025em;line-height:1.04;font-size:clamp(2.4rem,5vw,4rem);color:var(--ink);margin:0 0 20px;text-wrap:balance;">Contact Djibril Kassogue</h1>
      <p style="font-family:var(--font-serif);font-size:1.15rem;line-height:1.7;color:var(--text-body);margin:0;max-width:58ch;">The fastest way to reach Djibril is WhatsApp. Send a few practical details and he can advise what is realistic for your dates.</p>
    </div>
  </section>

  <!-- First-message panel (same pattern as homepage) -->
  <section style="background:var(--cream);padding:clamp(3rem,6vw,5rem) 0 clamp(4rem,8vw,6.5rem);">
    <div class="container-site">
      <div class="first-msg-card">
        <div>
          <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:11.5px;color:var(--clay-text);margin:0 0 14px;">Your first message</p>
          <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.015em;line-height:1.08;font-size:clamp(1.7rem,2.6vw,2.4rem);color:var(--ink);margin:0 0 16px;">You do not need a finished itinerary</h2>
          <p style="font-family:var(--font-serif);font-size:1.08rem;line-height:1.65;color:var(--text-body);margin:0 0 26px;max-width:42ch;">Send a few practical details on WhatsApp and Djibril will tell you what is realistic, what may need adjusting, and how to plan it responsibly.</p>
        </div>
        <div style="background:var(--tag-bg);border:1px solid var(--sand);border-radius:14px;padding:26px 28px;">
          <p style="font-family:var(--font-ui);font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin:0 0 16px;">What to send</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px 20px;">
            {checklist.map((item) => (
              <div style="display:flex;align-items:flex-start;gap:9px;font-family:var(--font-serif);font-size:0.98rem;color:var(--text-body);">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--forest)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact info -->
  <section style="background:#fff;border-top:1px solid var(--sand);padding:clamp(4rem,8vw,6.5rem) 0;">
    <div class="container-site" style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,5vw,72px);align-items:start;">
      <div>
        <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:0.75rem;color:var(--clay-text);margin:0 0 18px;">Contact details</p>
        <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.015em;line-height:1.06;font-size:clamp(1.8rem,3vw,2.6rem);color:var(--ink);margin:0 0 24px;">Ways to reach Djibril</h2>
        <div style="display:grid;gap:14px;">
          {contactLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noopener" style="display:flex;align-items:center;gap:12px;padding:16px 20px;background:var(--cream);border:1px solid var(--sand);border-radius:12px;font-family:var(--font-ui);font-weight:600;font-size:0.95rem;color:var(--ink);text-decoration:none;transition:box-shadow 180ms ease,transform 180ms ease;" class="contact-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--clay-text)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              {link.label}
            </a>
          ))}
        </div>
      </div>
      <div style="background:var(--tag-bg);border:1px solid var(--sand);border-radius:14px;padding:clamp(22px,3vw,36px);">
        <p style="font-family:var(--font-ui);font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);margin:0 0 18px;">Planning note</p>
        <p style="font-family:var(--font-serif);font-size:1.05rem;line-height:1.7;color:var(--text-body);margin:0 0 18px;">Routes depend on current conditions, transport, border rules, visas, and local feasibility. Djibril can advise what may need adjustment before you commit to a plan.</p>
        <p style="font-family:var(--font-serif);font-size:0.95rem;line-height:1.65;color:var(--text-muted);margin:0;">WhatsApp is the fastest and most reliable channel. Response times vary — if your dates are soon, say so in your first message.</p>
      </div>
    </div>
  </section>

  <FinalCTA
    title="Ready to plan your trip?"
    lead="Message Djibril on WhatsApp with your dates, group size, and route ideas. He will advise what is realistic."
  />

</BaseLayout>

<style>
  .first-msg-card {
    background: white;
    border: 1px solid var(--sand);
    border-radius: 18px;
    box-shadow: var(--shadow-hero-card);
    padding: clamp(28px, 4vw, 44px);
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }

  .contact-link:hover {
    box-shadow: var(--shadow-raised);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .first-msg-card {
      grid-template-columns: 1fr;
    }
    .container-site > div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
