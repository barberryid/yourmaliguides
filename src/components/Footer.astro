---
import { site } from "@config/site";
const year = new Date().getFullYear();
const waHref = `${site.whatsappUrl}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<footer style="background:var(--ink);color:var(--text-on-dark);">
  <div class="container-site" style="display:grid;grid-template-columns:1.6fr 1fr 1.2fr;gap:48px;padding-block:clamp(3.5rem,7vw,5rem);">
    <!-- Brand -->
    <div>
      <a href="/" style="display:inline-flex;align-items:center;gap:10px;text-decoration:none;margin-bottom:16px;">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:9px;background:var(--clay);color:var(--cream);font-family:var(--font-ui);font-weight:800;font-size:12px;">YMG</span>
        <span style="font-family:var(--font-display);font-weight:600;font-size:1.15rem;color:var(--cream);">Your Mali Guides</span>
      </a>
      <p style="font-family:var(--font-serif);font-size:0.95rem;line-height:1.65;color:rgba(244,239,228,0.72);max-width:30ch;margin:0 0 24px;">
        Private guiding, cultural interpretation, and safety-aware route planning in Mali and West Africa.
      </p>
    </div>

    <!-- Explore -->
    <div>
      <p class="ymg-foot-label">Explore</p>
      <div class="ymg-foot-links" style="margin-top:16px;display:grid;gap:10px;">
        {site.mainNav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    </div>

    <!-- Contact -->
    <div>
      <p class="ymg-foot-label">Contact</p>
      <div class="ymg-foot-links" style="margin-top:16px;display:grid;gap:10px;">
        <a href={waHref} target="_blank" rel="noopener">WhatsApp: +{site.whatsappNumber}</a>
        <a href={site.facebookUrl} target="_blank" rel="noopener">Facebook: Djibril Kassogue</a>
        <a href={site.instagramUrl} target="_blank" rel="noopener">Instagram: @djibril_kassogue</a>
      </div>
      <p style="margin-top:20px;font-family:var(--font-ui);font-size:0.8rem;line-height:1.6;color:rgba(244,239,228,0.45);">Routes depend on current local conditions, border rules, visas, and practical feasibility.</p>
    </div>
  </div>

  <div style="border-top:1px solid rgba(244,239,228,0.14);padding-block:20px;">
    <div class="container-site" style="font-family:var(--font-ui);font-size:0.78rem;color:rgba(244,239,228,0.45);">
      &copy; {year} Your Mali Guides · Mali and West Africa private guide services.
    </div>
  </div>
</footer>

<style>
  .ymg-foot-label {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .ymg-foot-links a {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: rgba(244,239,228,0.65);
    text-decoration: none;
    transition: color 160ms ease;
  }
  .ymg-foot-links a:hover {
    color: var(--cream);
  }
  @media (max-width: 767px) {
    footer .container-site {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
  }
</style>
