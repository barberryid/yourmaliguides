---
import { site } from "@config/site";

interface Props {
  image: string;
  alt: string;
  eyebrow: string;
  title: string;
  lead?: string;
  waTopic?: string;
  waLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  minHeight?: string;
  imagePosition?: string;
}

const {
  image,
  alt,
  eyebrow,
  title,
  lead,
  secondaryHref,
  secondaryLabel,
  minHeight = "62vh",
  imagePosition = "center 40%",
} = Astro.props;
---

<section style={`position:relative;min-height:${minHeight};display:flex;align-items:flex-end;`}>
  <div style="position:absolute;inset:0;overflow:hidden;">
    <img
      src={image}
      alt={alt}
      width="1600" height="900"
      fetchpriority="high"
      decoding="async"
      style={`width:100%;height:100%;object-fit:cover;object-position:${imagePosition};`}
    />
    <div style="position:absolute;inset:0;background:var(--overlay-hero);"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(96deg, rgba(21,32,29,0.60) 0%, rgba(21,32,29,0.22) 46%, rgba(21,32,29,0) 80%);"></div>
  </div>
  <div style="position:relative;width:100%;max-width:var(--content-max);margin:0 auto;padding:clamp(5rem,10vw,8rem) var(--gutter) clamp(3.5rem,6vw,5.5rem);">
    <div style="max-width:720px;">
      <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:12px;color:var(--gold);margin:0 0 18px;">{eyebrow}</p>
      <h1 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.025em;line-height:1.02;font-size:clamp(2.4rem,5vw,4.2rem);color:var(--cream);margin:0 0 20px;text-wrap:balance;">{title}</h1>
      {lead && (
        <p style="font-family:var(--font-serif);font-size:clamp(1.05rem,1.5vw,1.2rem);line-height:1.65;color:rgba(244,239,228,0.9);margin:0 0 30px;max-width:580px;">{lead}</p>
      )}
      {secondaryHref && (
        <a href={secondaryHref} style="display:inline-flex;align-items:center;gap:8px;font-family:var(--font-ui);font-weight:600;font-size:15px;background:rgba(253,250,243,0.08);color:var(--cream);padding:14px 22px;border-radius:10px;text-decoration:none;border:1px solid rgba(244,239,228,0.35);backdrop-filter:blur(4px);">
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</section>
