---
import WhatsAppIcon from "./WhatsAppIcon.astro";
import { site } from "@config/site";

const {
  label = "Message Djibril on WhatsApp",
  className = "btn btn-whatsapp",
  subject = site.whatsappMessage,
  ariaLabel,
} = Astro.props;

const href = subject
  ? `${site.whatsappUrl}?text=${encodeURIComponent(subject)}`
  : site.whatsappUrl;
---

<a class={className} href={href} target="_blank" rel="noopener" aria-label={ariaLabel ?? label}>
  <WhatsAppIcon />
  <span>{label}</span>
</a>
