---
interface Props {
  eyebrow?: string;
  title?: string;
  lead?: string;
}

const {
  eyebrow = "Plan with a local guide",
  title = "Plan a realistic private trip in Mali",
  lead = "Contact Djibril to start a conversation about your dates, interests, and what is realistic for your trip.",
} = Astro.props;
---

<section style="position:relative;padding:clamp(4.5rem,9vw,7.5rem) 0;overflow:hidden;text-align:center;">
  <div style="position:absolute;inset:0;">
    <img src="/images/village-ceremony.jpg" alt="" aria-hidden="true" width="1600" height="900" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;" />
    <div style="position:absolute;inset:0;background:linear-gradient(180deg, rgba(21,32,29,0.78), rgba(21,32,29,0.70));"></div>
  </div>
  <div class="container-site" style="position:relative;max-width:760px;">
    <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:12px;color:var(--gold);margin:0 0 20px;">{eyebrow}</p>
    <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.02em;line-height:1.05;font-size:clamp(2.2rem,4.5vw,3.6rem);color:var(--cream);margin:0 0 20px;text-wrap:balance;">{title}</h2>
    <p style="font-family:var(--font-serif);font-size:clamp(1.05rem,1.5vw,1.18rem);line-height:1.65;color:rgba(244,239,228,0.88);margin:0 0 36px;max-width:54ch;margin-inline:auto;">{lead}</p>
    <a href="/contact/" style="display:inline-flex;align-items:center;gap:10px;font-family:var(--font-ui);font-weight:600;font-size:16px;background:var(--clay);color:var(--cream);padding:16px 30px;border-radius:10px;text-decoration:none;box-shadow:var(--shadow-raised);">
      Contact Djibril →
    </a>
  </div>
</section>
