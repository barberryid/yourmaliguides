---
import { site } from "@config/site";

interface Props {
  eyebrow?: string;
  title?: string;
  lead?: string;
  waLabel?: string;
  waTopic?: string;
}

const {
  eyebrow = "Plan with a local guide",
  title = "Plan a realistic private trip in Mali",
  lead = "Message Djibril on WhatsApp to start a conversation about your dates, interests, and what is realistic for your trip.",
  waLabel = "Message Djibril on WhatsApp",
  waTopic,
} = Astro.props;

const msg = waTopic
  ? `Hello Djibril, I am interested in ${waTopic}. My dates are: ___. Number of travellers: ___. Could you advise what is realistic?`
  : site.whatsappMessage;
const waHref = `${site.whatsappUrl}?text=${encodeURIComponent(msg)}`;
---

<section style="position:relative;padding:clamp(4.5rem,9vw,7.5rem) 0;overflow:hidden;text-align:center;">
  <div style="position:absolute;inset:0;">
    <img src="/images/village-ceremony.jpg" alt="" aria-hidden="true" width="1600" height="900" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;" />
    <div style="position:absolute;inset:0;background:linear-gradient(180deg, rgba(21,32,29,0.78), rgba(21,32,29,0.70));"></div>
  </div>
  <div class="container-site" style="position:relative;max-width:760px;">
    <p style="font-family:var(--font-ui);font-weight:800;text-transform:uppercase;letter-spacing:0.18em;font-size:12px;color:var(--gold);margin:0 0 20px;">{eyebrow}</p>
    <h2 style="font-family:var(--font-display);font-weight:600;letter-spacing:-0.02em;line-height:1.05;font-size:clamp(2.2rem,4.5vw,3.6rem);color:var(--cream);margin:0 0 20px;text-wrap:balance;">{title}</h2>
    <p style="font-family:var(--font-serif);font-size:clamp(1.05rem,1.5vw,1.18rem);line-height:1.65;color:rgba(244,239,228,0.88);margin:0 0 36px;max-width:54ch;margin-inline:auto;">{lead}</p>
    <a href={waHref} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:10px;font-family:var(--font-ui);font-weight:600;font-size:16px;background:var(--clay);color:var(--cream);padding:16px 30px;border-radius:10px;text-decoration:none;box-shadow:var(--shadow-raised);margin-bottom:18px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8 0-1.3.7-2 .9-2.2.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2 .8.6 1.4.8 1.7 1 .2.1.4.1.5-.1l.7-.8c.2-.2.3-.2.6-.1l1.8.9c.3.1.4.2.5.3.1.2.1.9-.1 1.6Z"/></svg>
      {waLabel}
    </a>
    <p style="font-family:var(--font-ui);font-size:0.8rem;color:rgba(244,239,228,0.5);">Dates · Group size · Places of interest · Preferred language · Travel pace</p>
  </div>
</section>
