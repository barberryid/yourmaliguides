---
import { site } from "@config/site";

interface Props {
  route: {
    title: string;
    image: string;
    alt: string;
    bestFor: string;
    note: string;
    feasibility: string;
    feasColor: string;
    topic: string;
    ideaUrl: string;
  };
}

const { route: r } = Astro.props;
---

<div class="route-card">
  <div style="position:relative;aspect-ratio:3/2;overflow:hidden;">
    <img src={r.image} alt={r.alt} width="540" height="360" loading="lazy" class="route-img" />
    <div style="position:absolute;inset:0;background:var(--overlay-image-top);"></div>
    <span style={`position:absolute;top:13px;left:13px;font-family:var(--font-ui);font-size:11.5px;font-weight:600;color:var(--cream);background:${r.feasColor};padding:5px 11px;border-radius:999px;backdrop-filter:blur(3px);`}>{r.feasibility}</span>
  </div>
  <div style="padding:22px 22px 24px;display:flex;flex-direction:column;flex:1;">
    <h3 style="font-family:var(--font-display);font-weight:600;font-size:1.4rem;letter-spacing:-0.01em;color:var(--ink);margin:0 0 10px;">{r.title}</h3>
    <p style="font-family:var(--font-serif);font-size:0.97rem;line-height:1.55;color:var(--text-body);margin:0 0 6px;">
      <span style="color:var(--clay-text);font-weight:600;">Best for </span>{r.bestFor}
    </p>
    <p style="font-family:var(--font-serif);font-size:0.97rem;line-height:1.55;color:var(--text-muted);margin:0 0 auto;">{r.note}</p>
    <div style="display:flex;align-items:center;padding-top:16px;margin-top:18px;border-top:1px solid var(--sand);">
      <a href={r.ideaUrl} style="font-family:var(--font-ui);font-weight:600;font-size:13.5px;color:var(--clay-text);text-decoration:none;">Route idea →</a>
    </div>
  </div>
</div>
