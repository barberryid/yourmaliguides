---
import WhatsAppLink from "./WhatsAppLink.astro";
const { tour } = Astro.props;
---

<article class="image-card group flex h-full flex-col">
  <a href={tour.href} class="block overflow-hidden">
    <img src={tour.image} alt={`${tour.title} with a local guide in Mali`} loading="lazy" class="h-64 w-full object-cover transition duration-500 group-hover:scale-105" />
  </a>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-serif text-2xl font-extrabold text-indigo-deep">{tour.title}</h3>
    <div class="mt-4 grid gap-3 text-slate-700">
      <p><strong class="text-indigo-deep">Best for:</strong> {tour.bestFor}</p>
      <p><strong class="text-indigo-deep">Experience:</strong> {tour.experience}</p>
      <p><strong class="text-indigo-deep">Planning note:</strong> {tour.note}</p>
    </div>
    <div class="mt-5 flex flex-wrap gap-3">
      <WhatsAppLink label={tour.cta} className="btn btn-whatsapp min-h-11 px-4 py-2 text-sm" subject={`Hello Djibril, I am interested in ${tour.title}. My dates are: _____. Number of travellers: _____. Could you advise what is realistic and safe?`} />
      <a class="btn btn-outline min-h-11 px-4 py-2 text-sm" href={tour.href}>See route idea</a>
    </div>
  </div>
</article>
