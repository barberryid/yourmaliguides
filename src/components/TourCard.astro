---
import WhatsAppLink from "./WhatsAppLink.astro";
const { tour } = Astro.props;
---

<article class="image-card group flex h-full flex-col">
  <a href={tour.href} class="block overflow-hidden">
    <img src={tour.image} alt={`${tour.title} with a local guide in Mali`} loading="lazy" class="h-64 w-full object-cover transition duration-500 group-hover:scale-105" />
  </a>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-serif text-2xl font-extrabold text-indigo-deep">{tour.title}</h3>
    <p class="mt-3 leading-7 text-slate-700">{tour.description}</p>
    <p class="mt-3 text-sm font-semibold text-clay">{tour.note}</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <WhatsAppLink label="Ask on WhatsApp" className="btn btn-whatsapp min-h-11 px-4 py-2 text-sm" subject={`Hello Djibril, I am interested in ${tour.title}. Can you help me plan this route?`} />
      <a class="btn btn-outline min-h-11 px-4 py-2 text-sm" href={tour.href}>Details</a>
    </div>
  </div>
</article>
