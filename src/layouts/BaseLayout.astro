---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import WhatsAppIcon from "@components/WhatsAppIcon.astro";
import { site } from "@config/site";
import "@styles/global.css";

const {
  title = "Your Mali Guides | Djibril Kassogue | Official Guide in Mali",
  description = site.defaultMetaDescription,
  image = "/images/mali-river-hero.webp",
  canonical = Astro.url.pathname,
} = Astro.props;

const canonicalUrl = new URL(canonical, site.baseUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(image, site.baseUrl).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, site.baseUrl).toString()} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,800&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <div class="fixed bottom-4 right-4 z-50">
      <a href={site.whatsappUrl} target="_blank" rel="noopener" aria-label="Contact Djibril Kassogue on WhatsApp" class="btn btn-whatsapp min-h-14 min-w-14 px-4 shadow-2xl">
        <WhatsAppIcon class="h-7 w-7" />
        <span class="hidden sm:inline">Chat with Djibril</span>
      </a>
    </div>
    <script>
      const toggle = document.querySelector("[data-menu-toggle]");
      const menu = document.querySelector("[data-mobile-menu]");
      toggle?.addEventListener("click", () => {
        const isOpen = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!isOpen));
        menu?.classList.toggle("hidden", isOpen);
      });
    </script>
  </body>
</html>
