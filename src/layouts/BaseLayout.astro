---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { site } from "@config/site";
import "@styles/global.css";

const {
  title = "Private Mali Guide & Cultural Tours | Your Mali Guides",
  description = site.defaultMetaDescription,
  image = site.defaultOgImage,
  imageAlt = site.defaultOgImageAlt,
  canonical = Astro.url.pathname,
  robots = "index, follow",
  ogType = "website",
  additionalSchema,
  heroHeader = false,
} = Astro.props;

const canonicalUrl = new URL(canonical, site.baseUrl).toString();
const ogImageUrl = new URL(image, site.baseUrl).toString();

// Auto-build a breadcrumb trail from the URL path so every sub-page emits
// BreadcrumbList structured data without each page having to declare it.
const segments = Astro.url.pathname.split("/").filter(Boolean);
const deslug = (s: string) =>
  s.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
const crumbs = [{ name: "Home", url: site.baseUrl + "/" }];
let acc = "";
for (const seg of segments) {
  acc += "/" + seg;
  crumbs.push({ name: site.pageLabels[seg] ?? deslug(seg), url: site.baseUrl + acc + "/" });
}
const breadcrumbSchema =
  crumbs.length > 1
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: crumbs.map((c, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: c.name,
          item: c.url,
        })),
      }
    : null;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.siteName,
  url: site.baseUrl + "/",
  inLanguage: "en",
  publisher: { "@type": "Organization", name: site.siteName },
};

const travelAgencySchema = {
  "@context": "https://schema.org",
  "@type": "TravelAgency",
  "@id": site.baseUrl + "/#travelagency",
  name: site.siteName,
  url: site.baseUrl + "/",
  image: ogImageUrl,
  description:
    "Private Mali guiding and cultural travel planning with local guide Djibril Kassogue.",
  telephone: "+" + site.whatsappNumber,
  knowsLanguage: ["English", "French"],
  areaServed: [
    { "@type": "Country", name: "Mali" },
    { "@type": "Place", name: "West Africa" },
  ],
  founder: {
    "@type": "Person",
    name: site.guideName,
    jobTitle: "Official local guide in Mali",
    url: site.baseUrl + "/about/",
  },
  sameAs: [site.instagramUrl, site.facebookUrl],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer service",
    telephone: "+" + site.whatsappNumber,
    availableLanguage: ["English", "French"],
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content={site.guideName} />
    <meta name="theme-color" content="#1f4c3b" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={site.siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(travelAgencySchema)} />
    {breadcrumbSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
    {additionalSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(additionalSchema)} />}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header heroHeader={heroHeader} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script>
      const toggle = document.querySelector("[data-menu-toggle]");
      const menu = document.querySelector("[data-mobile-menu]");
      const setMenu = (open: boolean) => {
        if (!toggle || !menu) return;
        toggle.setAttribute("aria-expanded", String(open));
        toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        menu.classList.toggle("open", open);
        menu.setAttribute("aria-hidden", String(!open));
      };
      const isOpen = () => toggle?.getAttribute("aria-expanded") === "true";
      toggle?.addEventListener("click", () => setMenu(!isOpen()));
      // Close when a link inside the menu is tapped
      menu?.querySelectorAll("a").forEach((link) =>
        link.addEventListener("click", () => setMenu(false))
      );
      // Close on Escape and reset when the panel loses focus
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && isOpen()) setMenu(false);
      });
    </script>
  </body>
</html>
