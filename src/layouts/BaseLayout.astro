---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import WhatsAppIcon from "@components/WhatsAppIcon.astro";
import { site } from "@config/site";
import "@styles/global.css";

const {
  title = "Private Mali Guide & Cultural Tours | Your Mali Guides",
  description = site.defaultMetaDescription,
  image = "/images/your-mali-guides-og.jpg",
  canonical = Astro.url.pathname,
  robots = "index, follow",
  additionalSchema,
} = Astro.props;

const canonicalUrl = new URL(canonical, site.baseUrl).toString();
const ogImageUrl = new URL(image, site.baseUrl).toString();
const whatsappHref = `${site.whatsappUrl}?text=${encodeURIComponent(site.whatsappMessage)}`;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.siteName,
  url: site.baseUrl + "/",
};

const travelAgencySchema = {
  "@context": "https://schema.org",
  "@type": "TravelAgency",
  name: site.siteName,
  url: site.baseUrl + "/",
  description:
    "Private Mali guiding and cultural travel planning with local guide Djibril Kassogue.",
  areaServed: {
    "@type": "Country",
    name: "Mali",
  },
  founder: {
    "@type": "Person",
    name: site.guideName,
    jobTitle: "Local Mali Guide",
    url: site.baseUrl + "/about/",
  },
  sameAs: [site.instagramUrl, site.facebookUrl],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer service",
    availableLanguage: ["English", "French"],
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={site.siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,800&family=Inter:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(travelAgencySchema)} />
    {additionalSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(additionalSchema)} />}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <div class="mobile-whatsapp-cta">
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener"
        aria-label="Message Djibril on WhatsApp with your dates, group size, and route idea"
        class="mobile-whatsapp-link"
      >
        <WhatsAppIcon class="h-7 w-7" />
        <span>
          <strong>Message Djibril on WhatsApp</strong>
          <small>Send your dates, group size, and route idea.</small>
        </span>
      </a>
    </div>
    <script>
      const toggle = document.querySelector("[data-menu-toggle]");
      const menu = document.querySelector("[data-mobile-menu]");
      toggle?.addEventListener("click", () => {
        const isOpen = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!isOpen));
        menu?.classList.toggle("hidden", isOpen);
      });
    </script>
  </body>
</html>
